{
  "name": "@seedprotocol/sdk",
  "version": "0.4.4",
  "description": "The SDK for Seed Protocol",
  "type": "module",
  "main": "./dist/main.cjs",
  "module": "./dist/main.js",
  "types": "./dist/index.d.ts",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">= 20 <= 24"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "node build/src/index.js",
    "clean": "rimraf coverage build tmp",
    "prebuild": "bun run lint",
    "build": "node scripts/build-with-tests.js \"tsc -p tsconfig.json\"",
    "build:watch": "tsc -w -p tsconfig.json",
    "build:release": "node scripts/build-with-tests.js \"bun run clean && tsc -p tsconfig.json\"",
    "lint": "eslint .",
    "test": "vitest run --reporter=default",
    "prettier": "prettier --config .prettierrc --write .",
    "test:ui": "vitest --ui --reporter=default",
    "test:watch": "vitest",
    "compile": "graphql-codegen --config codegen.ts",
    "watch": "graphql-codegen -w",
    "build:dev": "node scripts/build-with-tests.js \"rm -rf dist && NODE_ENV=production rollup -c && node scripts/check-dist-no-alias.js && tsc -p tsconfig.declarations.json\"",
    "build:publish": "node scripts/build-with-tests.js \"bun run sync-versions && rm -rf dist && NODE_ENV=production rollup -c && node scripts/check-dist-no-alias.js && tsc -p tsconfig.declarations.json && npm publish --access public\"",
    "build:cli": "node scripts/build-with-tests.js \"cd packages/cli && bun run build\"",
    "build:all": "node scripts/build-with-tests.js \"bun run sync-versions && bun run build && bun run build:cli\"",
    "sync-versions": "node scripts/sync-versions.js",
    "version": "node scripts/sync-versions.js",
    "test:browser": "vitest --project=browser",
    "rpc-server": "tsx scripts/rpcServer.ts",
    "cli": "tsx packages/cli/src/bin.ts",
    "cli:init": "tsx packages/cli/src/bin.ts init",
    "cli:export-sql": "tsx packages/cli/src/bin.ts export-sql",
    "cli:seed": "tsx packages/cli/src/bin.ts seed",
    "drizzle:track": "tsx scripts/track-drizzle-changes.ts"
  },
  "author": "Keith Axline <keith@journodao.xyz>",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18 || ^19",
    "@tanstack/react-query": "^5"
  },
  "optionalDependencies": {
    "@tanstack/react-query": "^5.90.15",
    "@zenfs/core": "^2.4.4",
    "@zenfs/dom": "^1.2.6",
    "fsevents": "^2.3.3"
  },
  "dependencies": {
    "@ethereum-attestation-service/eas-sdk": "^2.9.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@libsql/client": "^0.15.15",
    "@misskey-dev/browser-image-resizer": "^2024.1.0",
    "@pianity/arsnap-adapter": "^0.2.0",
    "@sinclair/typebox": "^0.34.45",
    "@sqlite.org/sqlite-wasm": "^3.51.1-build2",
    "@statelyai/inspect": "^0.4.0",
    "@tanstack/query-sync-storage-persister": "^5.90.17",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@tanstack/react-query-persist-client": "^5.90.17",
    "@xstate/react": "^6.0.0",
    "arweave": "^1.15.5",
    "better-sqlite3": "^12.5.0",
    "debug": "^4.4.1",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.44.3",
    "ethers": "^6.13.0",
    "eventemitter3": "^5.0.1",
    "glob": "^13.0.0",
    "globals": "^16.5.0",
    "graphql": "^16.10.0",
    "graphql-request": "^7.3.5",
    "immer": "^11.0.1",
    "js-sha3": "^0.9.3",
    "js-yaml": "^4.1.1",
    "lodash-es": "^4.17.22",
    "nanoid": "^5.1.5",
    "nanoid-dictionary": "^5.0.0",
    "nunjucks": "^3.2.4",
    "path-browserify": "^1.0.1",
    "pluralize": "^8.0.0",
    "protobufjs": "^7.4.0",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.1",
    "sqlocal": "^0.16.0",
    "threads": "^1.7.0",
    "ts-import": "5.0.0-beta.1",
    "ts-morph": "^27.0.2",
    "ts-proto": "^2.6.0",
    "tslib": "^2.8.1",
    "use-immer": "^0.11.0",
    "vite-plugin-node-polyfills": "^0.24.0",
    "webpack": "^5.98.0",
    "xstate": "^5.19.0"
  },
  "devDependencies": {
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@esbuild/darwin-arm64": "^0.27.2",
    "@esbuild/darwin-x64": "^0.27.2",
    "@graphql-codegen/cli": "^6.0.1",
    "@graphql-codegen/client-preset": "^5.2.2",
    "@graphql-codegen/introspection": "5.0.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-dynamic-import-vars": "^2.1.5",
    "@rollup/plugin-esm-shim": "^0.1.7",
    "@rollup/plugin-inject": "^5.0.5",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-legacy": "^3.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.2",
    "@rollup/plugin-typescript": "^12.1.2",
    "@rollup/plugin-virtual": "^3.0.2",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@tanstack/react-query": "^5.62.11",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.13",
    "@types/lodash-es": "^4.17.12",
    "@types/mock-fs": "^4.13.4",
    "@types/nanoid-dictionary": "^4.2.3",
    "@types/node": "^24.10.1",
    "@types/nunjucks": "^3.2.6",
    "@types/path-browserify": "^1.0.3",
    "@types/pluralize": "^0.0.33",
    "@types/qs": "^6.9.16",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser": "^4.0.16",
    "@vitest/browser-playwright": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "eslint": "9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "express": "^5.2.1",
    "jsdom": "^27.1.0",
    "mock-fs": "^5.4.1",
    "playwright": "^1.57.0",
    "postcss": "^8.4.49",
    "prettier": "^3.7.3",
    "prettier-eslint": "^16.3.0",
    "prettier-plugin-organize-imports": "^4.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rollup": "^4.53.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-css-only": "^4.5.2",
    "rollup-plugin-dts": "^6.3.0",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "rollup-plugin-preserve-shebang": "^1.0.1",
    "rollup-plugin-string": "^3.0.0",
    "rollup-plugin-strip-shebang": "^2.0.0",
    "rollup-plugin-tsconfig-paths": "^1.5.2",
    "rollup-plugin-web-worker-loader": "^1.6.1",
    "supports-color": "^10.0.0",
    "ts-api-utils": "~2.1.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typia": "^10.0.0",
    "vite": "^7.3.0",
    "vite-plugin-inspect": "^11.3.3",
    "vite-plugin-static-copy": "^3.1.4",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "^4.0.16",
    "vitest-browser-react": "^2.0.2"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/main.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/main.cjs"
      }
    },
    "./node": {
      "import": {
        "types": "./dist/node/index.d.ts",
        "default": "./dist/node.js"
      },
      "require": {
        "types": "./dist/node/index.d.ts",
        "default": "./dist/main.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite/index.d.ts",
        "default": "./dist/vite.js"
      },
      "require": {
        "types": "./dist/vite/index.d.ts",
        "default": "./dist/vite.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "trustedDependencies": [
    "protobufjs"
  ],
  "_bundleHint": {
    "note": "If bundling this package, mark the following as external: nunjucks, fsevents, better-sqlite3, drizzle-kit, and other native Node.js modules. For Vite projects, also exclude drizzle-kit and database drivers (@electric-sql/pglite, pg, postgres, etc.) from optimizeDeps."
  }
}
