    "@vitest/browser-playwright": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "eslint": "9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "express": "^5.2.1",
    "jsdom": "^27.1.0",
    "magic-string": "^0.30.21",
    "playwright": "^1.57.0",
    "postcss": "^8.4.49",
    "prettier": "^3.7.3",
    "prettier-plugin-organize-imports": "^4.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.53.0",
    "rollup-plugin-copy": "^3.5.0",
