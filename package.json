  "description": "Seed Protocol SDK monorepo",
  "engines": {
    "node": ">= 20 <= 24"
  },
  "license": "MIT",
  "packageManager": "yarn@4.5.3+sha512.3003a14012e2987072d244c720506549c1aab73ee728208f1b2580a9fd67b92d61ba6b08fe93f6dce68fd771e3af1e59a0afa28dd242dd0940d73b95fedd4e90",
  "private": true,
  "scripts": {
    "build": "bun run --filter @seedprotocol/sdk build:dev",
    "build:sdk": "bun run --filter @seedprotocol/sdk build:dev",
    "build:watch": "cd packages/sdk && tsc -w -p tsconfig.json",
    "build:cli": "node scripts/build-with-tests.js \"cd packages/cli && bun run build\"",
    "build:publish": "node scripts/build-with-tests.js \"cd packages/publish && bun run build\"",
    "build:feed": "node scripts/build-with-tests.js \"cd packages/feed && bun run build\"",
    "build:ghost": "node scripts/build-with-tests.js \"cd packages/ghost && bun run build\"",
    "build:react": "node scripts/build-with-tests.js \"bun run --filter @seedprotocol/react build\"",
    "build:all": "node scripts/build-with-tests.js \"bun run sync-versions && bun run build:feed && bun run build:sdk && bun run build:cli && bun run build:publish\"",
    "clean": "rimraf coverage build tmp",
    "lint": "eslint .",
    "test": "vitest run --reporter=default",
    "prettier": "prettier --config .prettierrc --write .",
    "test:ui": "vitest --ui --reporter=default",
    "test:watch": "vitest",
    "test:browser": "vitest --project=browser",
    "compile": "cd packages/sdk && graphql-codegen --config codegen.ts",
    "watch": "cd packages/sdk && graphql-codegen -w",
    "sync-versions": "node scripts/sync-versions.js",
    "version": "node scripts/sync-versions.js",
    "rpc-server": "tsx scripts/rpcServer.ts",
    "cli": "tsx packages/cli/src/bin.ts",
    "cli:init": "tsx packages/cli/src/bin.ts init",
    "cli:export-sql": "tsx packages/cli/src/bin.ts export-sql",
    "cli:seed": "tsx packages/cli/src/bin.ts seed",
    "drizzle:track": "tsx scripts/track-drizzle-changes.ts",
    "check:dist:fragile": "node scripts/check-dist-fragile-dynamic-imports.js",
    "publish:all": "node scripts/publish-package.js",
    "publish:sdk": "node scripts/publish-package.js sdk",
    "publish:react": "node scripts/publish-package.js react",
    "publish:feed": "node scripts/publish-package.js feed",
    "publish:publish": "node scripts/publish-package.js publish",
    "publish:cli": "node scripts/publish-package.js cli",
    "publish:ghost": "node scripts/publish-package.js ghost"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ]
}
