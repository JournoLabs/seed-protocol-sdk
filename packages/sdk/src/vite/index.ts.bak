import type { Plugin, ResolvedConfig } from 'vite'
import { readFileSync } from 'node:fs'
import { createRequire } from 'node:module'
import { dirname, join } from 'node:path'
import { fileURLToPath } from 'node:url'
import { nodePolyfills } from 'vite-plugin-node-polyfills'

// Get the plugin file's URL to use as importer context for resolving SDK dependencies
// @ts-ignore - rollup plugin-typescript doesn't recognize import.meta with module: "preserve"
// This is safe because import.meta.url is available at runtime in ESM contexts
const PLUGIN_FILE_URL: string = import.meta.url

// Create a require function for resolving CJS modules
// This is used to find the CJS build of packages that have problematic ESM exports
const require = createRequire(import.meta.url)

export interface SeedVitePluginOptions {
  /**
   * Custom ZenFS configuration to apply on initialization
   */
  zenfsConfig?: Record<string, unknown>
  
  /**
   * Additional modules to alias to ZenFS equivalents
   * @default ['fs', 'fs/promises', 'node:fs', 'node:fs/promises']
   */
  fsModules?: string[]
  
  /**
   * Whether to inject automatic ZenFS initialization
   * @default true
   */
  autoInit?: boolean
  
  /**
   * Enable debug logging
   * @default false
   */
  debug?: boolean
  
  /**
   * Entry points to scan for dependencies during initial optimization.
   * This helps prevent incremental dependency discovery and multiple reloads.
   * Can be file paths or glob patterns relative to the project root.
   * If not provided, the plugin will attempt to auto-detect SDK entry points.
   */
  entryPoints?: string[]
  
  /**
   * Whether to automatically include common SDK dependencies in optimizeDeps.include.
   * Set to false if these dependencies are not installed in your project.
   * @default false
   */
  autoIncludeDeps?: boolean
  
  /**
   * Whether to automatically configure vite-plugin-node-polyfills if available.
   * When true, the plugin will automatically set up node polyfills for buffer, events, util, and process.
   * Set to false if you want to configure vite-plugin-node-polyfills manually.
   * @default true
   * @deprecated Use `includeNodePolyfills` instead. This option will be removed in a future version.
   */
  autoConfigurePolyfills?: boolean
  
  /**
   * Whether to automatically include vite-plugin-node-polyfills in the plugin array.
   * When true (default), the SDK will add vite-plugin-node-polyfills with optimal settings.
   * Set to false if you want to configure vite-plugin-node-polyfills manually with custom settings.
   * @default true
   */
  includeNodePolyfills?: boolean
  
  /**
   * Enable the generic require() transformer for Vite-optimized files.
   * When true (default), the plugin will automatically transform require() calls to ESM imports
   * in files from Vite's optimization directories (.vite/deps, .vite-electron-renderer, etc.).
   * This eliminates "Dynamic require of X is not supported" errors without manual package exclusions.
   * @default true
   */
  transformRequires?: boolean
  
  /**
   * Modules that should NOT be transformed by the require() transformer (already ESM-safe).
   * These modules will be skipped even if they contain require() calls.
   * @default ['@zenfs/core', 'path-browserify', 'lodash-es', 'graphql-request']
   */
  esmSafeModules?: string[]
  
  /**
   * Module name mappings for require() transformations.
   * Maps CommonJS module names to their ESM-compatible equivalents.
   * For example: { 'path': 'path-browserify', 'fs': '@zenfs/core' }
   * These mappings are merged with the default mappings.
   * @default { 'path': 'path-browserify', 'fs': '@zenfs/core', ... }
   */
  moduleReplacements?: Record<string, string>
}

/**
 * The seed-vite-plugin automatically configures your Vite project for browser compatibility.
 * 
 * It includes vite-plugin-node-polyfills with optimal settings by default.
 * 
 * Basic usage (recommended):
 * ```ts
 * import { seedVitePlugin } from '@seedprotocol/sdk/vite'
 * 
 * export default defineConfig({
 *   plugins: [...seedVitePlugin()],
 * })
 * ```
 * 
 * Advanced usage (custom polyfill config):
 * ```ts
 * import { nodePolyfills } from 'vite-plugin-node-polyfills'
 * import { seedVitePlugin } from '@seedprotocol/sdk/vite'
 * 
 * export default defineConfig({
 *   plugins: [
 *     ...seedVitePlugin({ includeNodePolyfills: false }),
 *     nodePolyfills({ ...yourCustomConfig }),
 *   ],
 * })
 * ```
 * 
 * The SDK plugin will automatically:
 * - Include vite-plugin-node-polyfills with optimal settings (unless disabled)
 * - Exclude the necessary modules from optimization
 * - Configure proper aliases for fs -> @zenfs/core
 * - Handle buffer/events polyfill interception
 */

const DEFAULT_FS_MODULES = [
  'fs',
  'fs/promises',
  'node:fs',
  'node:fs/promises',
]

// Modules that other polyfill plugins commonly alias fs to
const KNOWN_POLYFILL_TARGETS = [
  'memfs',
  'browserfs',
  'rollup-plugin-node-polyfills/polyfills/fs',
  'vite-plugin-node-polyfills/shims/fs',
  'node-stdlib-browser/esm/mock/empty',
  'node-stdlib-browser/esm/mock/empty.js',
  '\0vite/node-polyfills/fs',
  '\0node-polyfills:fs',
  'empty',
  '\0empty',
  '__vite-browser-external',
]

// Common dependencies that are frequently used by the SDK and should be pre-optimized
// to prevent incremental discovery and multiple reloads
// Note: Only include these if autoIncludeDeps is enabled, as they might not be
// installed in the consuming project (they're in the SDK's node_modules)
const COMMON_DEPENDENCIES = [
  '@zenfs/core',
  '@zenfs/dom',
  'path-browserify',
  'graphql-request',
  'tslib',
  'reflect-metadata',
  '@sinclair/typebox',
  '@sinclair/typebox/value',
  'immer',
  'rxjs',
  'xstate',
  'lodash-es',
  'use-immer',
  '@xstate/react',
  'ethers',
  'eventemitter3',
  '@statelyai/inspect',
  'arweave',
  // Note: node:crypto is a Node.js built-in and cannot be optimized
]

// Default module replacements for require() transformations
// Maps CommonJS module names to their ESM-compatible browser equivalents
const DEFAULT_MODULE_REPLACEMENTS: Record<string, string> = {
  'path': 'path-browserify',
  'node:path': 'path-browserify',
  'fs': '@zenfs/core',
  'node:fs': '@zenfs/core',
  'fs/promises': '@zenfs/core/promises',
  'node:fs/promises': '@zenfs/core/promises',
  'buffer': 'buffer',
  'node:buffer': 'buffer',
  'events': 'events',
  'node:events': 'events',
  'util': 'util',
  'node:util': 'util',
  'stream': 'stream-browserify',
  'node:stream': 'stream-browserify',
  'crypto': 'crypto-browserify',
  'node:crypto': 'crypto-browserify',
  'process': 'process',
  'process/': 'process',
  'assert': 'assert',
  'node:assert': 'assert',
  'url': 'url',
  'node:url': 'url',
  'querystring': 'querystring-es3',
  'node:querystring': 'querystring-es3',
  'os': 'os-browserify/browser',
  'node:os': 'os-browserify/browser',
  'zlib': 'browserify-zlib',
  'node:zlib': 'browserify-zlib',
  'http': 'stream-http',
  'node:http': 'stream-http',
  'https': 'https-browserify',
  'node:https': 'https-browserify',
  'string_decoder': 'string_decoder',
  'node:string_decoder': 'string_decoder',
  'punycode': 'punycode',
  'node:punycode': 'punycode',
}

// Modules that are known to be ESM-safe and should NOT be transformed
// even if they appear in Vite's optimization directories
const DEFAULT_ESM_SAFE_MODULES = [
  '@zenfs/core',
  '@zenfs/dom',
  'path-browserify',
  'lodash-es',
  'graphql-request',
  'buffer/',  // The buffer polyfill itself
  'events/',  // The events polyfill itself
  'process/',  // The process polyfill itself
  'util/',    // The util polyfill itself
  'stream-browserify',
  'crypto-browserify',
  'assert/',
  'url/',
  'querystring-es3',
  'os-browserify',
  'browserify-zlib',
  'stream-http',
  'https-browserify',
  'string_decoder/',
  'punycode/',
  // Vite's own modules
  'vite/',
  '@vite/',
  // Our SDK
  'seed-protocol-sdk',
  '@seedprotocol/sdk',
]

export function seedVitePlugin(options: SeedVitePluginOptions = {}): Plugin[] {
  const {
    fsModules = DEFAULT_FS_MODULES,
    autoInit = true,
    debug = false,
    entryPoints,
    autoIncludeDeps = false,
    autoConfigurePolyfills = true,
    includeNodePolyfills = true,
    transformRequires = true,
    esmSafeModules = [],
    moduleReplacements = {},
  } = options

  const log = (...args: unknown[]) => {
    if (debug) console.log('[seed-vite-plugin]', ...args)
  }

  let config: ResolvedConfig

  // Track what other plugins have done to fs
  const interceptedResolutions = new Map<string, string>()

  // We'll create a plugin that loads vite-plugin-node-polyfills on demand
  // This allows us to check if it's available and configure it automatically

  /**
   * First plugin: runs early to observe what other plugins do and set up aliases
   */
  const observerPlugin: Plugin = {
    name: 'seed-protocol:observer',
    enforce: 'pre',

    config(userConfig, env) {
      // Set up aliases early to override other plugins' fs polyfills
      const aliases: Array<{ find: string | RegExp; replacement: string }> = []
      
      for (const fsModule of fsModules) {
        const isPromiseVariant = fsModule.includes('promises')
        const zenfsModule = isPromiseVariant ? '@zenfs/core/promises' : '@zenfs/core'
        aliases.push({
          find: new RegExp(`^${fsModule.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')}$`),
          replacement: zenfsModule,
        })
      }
      
      // Note: We don't alias buffer here because vite-plugin-node-polyfills handles it
      // when configured with include: ['buffer']. The alias would conflict with the plugin's
      // own resolution mechanism. Instead, we ensure buffer is excluded from optimization
      // and let vite-plugin-node-polyfills handle the polyfill injection.
      
      // Also alias the node-stdlib-browser empty mock to @zenfs/core
      // This ensures Vite can resolve it properly without needing manual resolution
      aliases.push(
        {
          find: /^node-stdlib-browser\/esm\/mock\/empty(\.js)?$/,
          replacement: '@zenfs/core',
        },
        {
          find: /node-stdlib-browser\/esm\/mock\/empty(\.js)?$/,
          replacement: '@zenfs/core',
        }
      )
      
      // Alias 'path' and 'node:path' to 'path-browserify' to ensure we always use the ESM-compatible polyfill
      // This is critical for Electron renderer processes where vite-plugin-node-polyfills
      // might create a problematic path polyfill that causes "Dynamic require" errors
      aliases.push(
        {
          find: /^path$/,
          replacement: 'path-browserify',
        },
        {
          find: /^node:path$/,
          replacement: 'path-browserify',
        }
      )
      
      // NOTE: We do NOT alias 'process' here because:
      // 1. Virtual modules (\0-prefixed) don't work with esbuild during dep optimization
      // 2. The npm 'process' package should be bundled normally by Vite
      // 3. vite-plugin-node-polyfills handles process polyfilling when configured
      // If you see "Dynamic require of process/" errors, ensure vite-plugin-node-polyfills
      // is configured with include: ['process'] and globals: { process: true }

      return {
        resolve: {
          alias: aliases,
        },
        optimizeDeps: {
          // NOTE: This exclude list works in conjunction with the generic require() transformer.
          // - Packages listed here won't be optimized by Vite, so their require() calls are
          //   handled by our load hook polyfills or aliases.
          // - Packages NOT listed here may be optimized by Vite. If they end up with require()
          //   calls in the optimized output, the generic require() transformer in the transform
          //   hook will convert them to ESM imports automatically.
          // This provides defense-in-depth: known problematic packages are excluded, and
          // any new packages that cause issues are handled by the transformer automatically.
          exclude: [
            // === Node.js built-in modules (aliased to browser polyfills) ===
            'fs', 
            'node:fs', 
            'fs/promises', 
            'node:fs/promises',
            'path',
            'node:path',
            'buffer',
            'node:buffer',
            'events',
            'util',
            'module',
            'node:module',
            // NOTE: Do NOT exclude 'process' - it needs to be bundled so that packages
            // like readable-stream can have their require('process/') calls resolved at bundle time
            
            // === Polyfill packages (handled by load hook with custom implementations) ===
            'path-browserify',
            'node-stdlib-browser/esm/mock/empty',
            'node-stdlib-browser/esm/mock/empty.js',
            
            // === CommonJS packages with load hook polyfills ===
            // These have full polyfill implementations in the load hook
            'picomatch',
            'create-require',
            'pkg-dir',
            
            // === vite-plugin-node-polyfills and its dependencies ===
            // These are build-time dependencies that should NOT be optimized.
            // They should NOT run in the browser at all.
            'vite-plugin-node-polyfills',
            'vite-plugin-node-polyfills/shims/buffer',
            'vite-plugin-node-polyfills/shims/global',
            'vite-plugin-node-polyfills/shims/process',
            '@rollup/plugin-inject',
            '@rollup/pluginutils',
            // Also exclude node-stdlib-browser since vite-plugin-node-polyfills imports it
            'node-stdlib-browser',
            'node-stdlib-browser/helpers/rollup/plugin',
            'node-stdlib-browser/helpers/esbuild/plugin',
            
            // === Drizzle ORM migrators (use node:fs internally) ===
            'drizzle-orm/migrator',
            'drizzle-orm/sqlite-proxy/migrator',
            'drizzle-orm/better-sqlite3/migrator',
            'drizzle-orm/libsql/migrator',
            
            // === Dev tools and database drivers (should not be bundled) ===
            'drizzle-kit',
            '@electric-sql/pglite',
            'pg',
            'postgres',
            '@vercel/postgres',
            '@neondatabase/serverless',
            'mysql2',
            'mysql2/promise',
            '@planetscale/database',
          ],
          // Note: We don't auto-include @zenfs/core here because it might not be installed
          // in the consuming project. The resolveId hook will help resolve it when needed.
        },
      }
    },

    async resolveId(source, importer, options) {
      // Remove query parameters for matching
      const sourceWithoutQuery = source.split('?')[0]
      
      // Intercept node-stdlib-browser/helpers/rollup/plugin and redirect to virtual module
      // This ensures our ESM wrapper is ALWAYS served, bypassing any /@fs/ caching issues
      if (
        sourceWithoutQuery.includes('node-stdlib-browser') && 
        sourceWithoutQuery.includes('helpers/rollup/plugin')
      ) {
        log(`[observer:resolveId] Redirecting node-stdlib-browser rollup plugin to virtual module`)
        // Return a virtual module ID that we control
        return '\0virtual:node-stdlib-browser-rollup-plugin'
      }
      
      // Intercept node-stdlib-browser/helpers/esbuild/plugin and redirect to virtual module
      // Same treatment as rollup plugin - CommonJS needs ESM wrapper
      if (
        sourceWithoutQuery.includes('node-stdlib-browser') && 
        sourceWithoutQuery.includes('helpers/esbuild/plugin')
      ) {
        log(`[observer:resolveId] Redirecting node-stdlib-browser esbuild plugin to virtual module`)
        // Return a virtual module ID that we control
        return '\0virtual:node-stdlib-browser-esbuild-plugin'
      }
      
      // NOTE: We do NOT intercept process/process/ here because virtual modules
      // don't work with esbuild during Vite's dependency optimization phase.
      // Instead, we let the npm 'process' package be bundled normally, or rely on
      // vite-plugin-node-polyfills to handle the polyfilling.
      
      // Intercept fs imports early, before other plugins can create polyfills
      // This is critical for packages like drizzle-orm/migrator that import node:fs
      if (fsModules.includes(source) || fsModules.includes(sourceWithoutQuery)) {
        log(`[observer] Early interception of: "${source}" from ${importer}`)
        
        const isPromiseVariant = source.includes('promises')
        const zenfsModule = isPromiseVariant ? '@zenfs/core/promises' : '@zenfs/core'
        
        // Resolve from plugin's context (SDK's node_modules)
        const resolved = await this.resolve(zenfsModule, PLUGIN_FILE_URL, {
          ...options,
          skipSelf: true,
        })
        
        if (resolved) {
          log(`[observer] Resolved to: ${resolved.id}`)
          return resolved
        }
      }
      
      // Also intercept node-stdlib-browser empty mock if it's being used
      // Match various formats: full path, relative path, with/without query params
      if (
        source.includes('node-stdlib-browser') && 
        (source.includes('mock/empty') || source.includes('empty.js'))
      ) {
        log(`[observer] Intercepting node-stdlib-browser empty mock: "${source}"`)
        const isPromiseVariant = source.includes('promises')
        const zenfsModule = isPromiseVariant ? '@zenfs/core/promises' : '@zenfs/core'
        
        // Try resolving from plugin context first (SDK's node_modules)
        let resolved = await this.resolve(zenfsModule, PLUGIN_FILE_URL, {
          ...options,
          skipSelf: true,
        })
        
        // If that fails and we have an importer, try resolving from the importer
        if (!resolved && importer) {
          resolved = await this.resolve(zenfsModule, importer, {
            ...options,
            skipSelf: true,
          })
        }
        
        if (resolved) {
          log(`[observer] Resolved empty mock to: ${resolved.id}`)
          return resolved
        }
        
        // If resolution fails, return null and let Vite handle it naturally
        // Vite should be able to resolve @zenfs/core from node_modules
        log(`[observer] Resolution failed, letting Vite handle: ${zenfsModule}`)
        return null
      }
      
      return null
    },

    // Load hook in observer (enforce: 'pre') to intercept CommonJS modules BEFORE Vite core
    // This is critical for node-stdlib-browser/helpers/rollup/plugin.js which is loaded
    // directly via /@fs/ and needs to be converted to ESM before the browser receives it
    load(id) {
      const idWithoutQuery = id.split('?')[0]
      
      // Handle the virtual module for node-stdlib-browser rollup plugin
      // This is the most reliable way to serve our ESM wrapper - using a virtual module
      // bypasses all Vite filesystem caching mechanisms
      if (id === '\0virtual:node-stdlib-browser-rollup-plugin') {
        log(`[observer:load] Serving virtual module for node-stdlib-browser rollup plugin`)
        return `
// Virtual module: node-stdlib-browser/helpers/rollup/plugin (ESM wrapper)
// This virtual module ensures the ESM wrapper is ALWAYS served

/**
 * Rollup warning handler that suppresses circular dependency warnings
 * from known packages that have safe circular dependencies.
 */
export function handleCircularDependancyWarning(warning, warningHandler) {
  const packagesWithCircularDependencies = [
    'util/',
    'assert/',
    'readable-stream/',
    'crypto-browserify/'
  ];
  if (
    !(
      warning.code === 'CIRCULAR_DEPENDENCY' &&
      packagesWithCircularDependencies.some((modulePath) => {
        if (typeof warning.importer !== 'string') {
          return false;
        }
        return warning.importer.includes(modulePath);
      })
    )
  ) {
    warningHandler(warning);
  }
}

export default { handleCircularDependancyWarning };
`
      }
      
      // Fallback: Intercept node-stdlib-browser/helpers/rollup/plugin.js directly
      // This handles cases where the file is loaded without going through resolveId first
      const isNodeStdlibBrowserRollupPlugin = 
        idWithoutQuery.includes('node-stdlib-browser') && 
        idWithoutQuery.includes('helpers/rollup/plugin')
      
      if (isNodeStdlibBrowserRollupPlugin) {
        log(`[observer:load] Intercepting node-stdlib-browser rollup plugin: ${id} - providing ESM wrapper`)
        return `
// Intercepted by seed-vite-plugin (observer:pre) - ESM wrapper for node-stdlib-browser/helpers/rollup/plugin.js
// This MUST be intercepted early (enforce: 'pre') to ensure ESM wrapper is served instead of CommonJS

/**
 * Rollup warning handler that suppresses circular dependency warnings
 * from known packages that have safe circular dependencies.
 */
export function handleCircularDependancyWarning(warning, warningHandler) {
  const packagesWithCircularDependencies = [
    'util/',
    'assert/',
    'readable-stream/',
    'crypto-browserify/'
  ];
  if (
    !(
      warning.code === 'CIRCULAR_DEPENDENCY' &&
      packagesWithCircularDependencies.some((modulePath) => {
        if (typeof warning.importer !== 'string') {
          return false;
        }
        return warning.importer.includes(modulePath);
      })
    )
  ) {
    warningHandler(warning);
  }
}

export default { handleCircularDependancyWarning };
`
      }
      
      // Handle the virtual module for node-stdlib-browser esbuild plugin
      if (id === '\0virtual:node-stdlib-browser-esbuild-plugin') {
        log(`[observer:load] Serving virtual module for node-stdlib-browser esbuild plugin`)
        return `
// Virtual module: node-stdlib-browser/helpers/esbuild/plugin (ESM wrapper)

function plugin(stdLibBrowser) {
  return {
    name: 'node-stdlib-browser-alias',
    setup(build) {
      // In browser context, this is a no-op stub
    }
  };
}

export default plugin;
export { plugin };
`
      }
      
      // Fallback: Intercept node-stdlib-browser/helpers/esbuild/plugin.js directly
      const isNodeStdlibBrowserEsbuildPlugin = 
        idWithoutQuery.includes('node-stdlib-browser') && 
        idWithoutQuery.includes('helpers/esbuild/plugin')
      
      if (isNodeStdlibBrowserEsbuildPlugin) {
        log(`[observer:load] Intercepting node-stdlib-browser esbuild plugin: ${id} - providing ESM wrapper`)
        return `
// Intercepted by seed-vite-plugin - ESM wrapper for esbuild plugin
function plugin(stdLibBrowser) {
  return {
    name: 'node-stdlib-browser-alias',
    setup(build) {}
  };
}
export default plugin;
export { plugin };
`
      }
      
      return null
    },

    configResolved(resolvedConfig) {
      config = resolvedConfig

      // Log any fs-related aliases from other plugins
      const aliases = resolvedConfig.resolve.alias
      if (debug && aliases) {
        const aliasArray = Array.isArray(aliases) ? aliases : Object.entries(aliases)
        for (const alias of aliasArray) {
          const [find, replacement] = Array.isArray(alias) 
            ? [alias[0], alias[1]] 
            : [alias.find, alias.replacement]
          
          if (typeof find === 'string' && fsModules.some(m => find.includes('fs'))) {
            log(`Detected existing alias: ${find} -> ${replacement}`)
          }
        }
      }
    },
  }

  /**
   * Main plugin: enforced to run last in the chain
   */
  const mainPlugin: Plugin = {
    name: 'seed-protocol:main',
    enforce: 'post',

    async config(userConfig, env) {
      // Pre-optimize common dependencies to prevent incremental discovery
      // This reduces the number of reloads by ensuring dependencies are optimized upfront
      // Note: Only include if autoIncludeDeps is true, as these dependencies might not
      // be installed in the consuming project (they're in the SDK's node_modules)
      const existingInclude = userConfig.optimizeDeps?.include || []
      // Normalize entries to always be an array (Vite allows string | string[])
      const existingEntriesRaw = userConfig.optimizeDeps?.entries
      const existingEntries = Array.isArray(existingEntriesRaw)
        ? existingEntriesRaw
        : existingEntriesRaw
        ? [existingEntriesRaw]
        : []
      
      const optimizeDepsConfig: {
        include?: string[]
        entries?: string[]
        esbuildOptions?: {
          define?: Record<string, string>
          inject?: string[]
        }
      } = {
        esbuildOptions: {
          define: {
            global: 'globalThis',
            // Inject process global for packages like readable-stream that check for it
            'process.env.NODE_DEBUG': 'false',
            'process.browser': 'true',
            'process.version': '"v16.0.0"',
          },
        },
      }

      // Only auto-include dependencies if explicitly enabled
      // Vite will discover dependencies automatically if they're imported
      if (autoIncludeDeps) {
        const include = Array.isArray(existingInclude)
          ? [...new Set([...existingInclude, ...COMMON_DEPENDENCIES])]
          : [...COMMON_DEPENDENCIES]
        optimizeDepsConfig.include = include
        if (debug) {
          log(`[main] Auto-including common dependencies: ${COMMON_DEPENDENCIES.join(', ')}`)
        }
      } else if (Array.isArray(existingInclude) && existingInclude.length > 0) {
        // Preserve existing includes if provided
        optimizeDepsConfig.include = existingInclude
      }

      // If entry points are provided, merge them with existing entries
      // This helps Vite discover all dependencies during initial optimization
      if (entryPoints && entryPoints.length > 0) {
        const mergedEntries = Array.isArray(existingEntries)
          ? [...new Set([...existingEntries, ...entryPoints])]
          : entryPoints
        optimizeDepsConfig.entries = mergedEntries
        if (debug) {
          log(`[main] Using entry points for dependency scanning: ${mergedEntries.join(', ')}`)
        }
      } else if (existingEntries.length > 0) {
        // Preserve existing entries even if none provided
        optimizeDepsConfig.entries = existingEntries
      }

      // Configure build externals to prevent bundling Node.js-only packages
      // These packages should not be bundled for browser builds
      const nodeOnlyPackages = [
        'drizzle-kit',
        '@electric-sql/pglite',
        'pg',
        'postgres',
        '@vercel/postgres',
        '@neondatabase/serverless',
        'mysql2',
        'mysql2/promise',
        '@planetscale/database',
        'better-sqlite3',
        'nunjucks',
        'fsevents',
      ]

      // Packages with ESM export patterns that Rollup can't properly trace
      // These need special handling via aliases to use their CJS builds instead
      // Note: We don't externalize these because browsers can't resolve bare specifiers
      const esmProblematicPackages: string[] = [
        // '@sinclair/typebox' is handled via alias to use CJS build instead
      ]

      // CommonJS dependencies that should be externalized for Node.js builds
      // NOTE: For browser/Electron renderer builds, these should NOT be externalized
      // as they need to be bundled with proper polyfills. We check isElectron below
      // to avoid externalizing these for renderer builds.
      // Packages like readable-stream, safe-buffer, string_decoder are commonly used
      // and can be bundled by Vite's esbuild with proper polyfill configuration.
      const commonjsDependencies: string[] = [
        // 'safe-buffer',      // Don't externalize - let Vite bundle it
        // 'readable-stream',  // Don't externalize - let Vite bundle it  
        // 'string_decoder',   // Don't externalize - let Vite bundle it
        'inherits',  // This one is safe to externalize as it's just a utility
      ]

      // Node.js built-in modules that should be externalized
      // Note: buffer should NOT be externalized for browser builds - it needs to be polyfilled
      // via vite-plugin-node-polyfills. Only externalize it for Node.js builds.
      const nodeBuiltins = [
        'url',
        'path',
        'http',
        'http2',
        'stream',
        'crypto',
        'net',
        'https',
        'zlib',
        'child_process',
        'fs',
        'fs/promises',
        'node:fs',
        'node:fs/promises',
        'node:url',
        'node:path',
        'node:http',
        'node:http2',
        'node:stream',
        'node:crypto',
        'node:net',
        'node:https',
        'node:zlib',
        'node:child_process',
        // Note: buffer and node:buffer are intentionally NOT in this list
        // They should be polyfilled via vite-plugin-node-polyfills for browser builds
      ]

      const existingExternal = userConfig.build?.rollupOptions?.external
      const existingExternalArray = Array.isArray(existingExternal)
        ? existingExternal
        : typeof existingExternal === 'string'
        ? [existingExternal]
        : []

      // Merge with existing externals, avoiding duplicates
      const allExternals = [
        ...new Set([
          ...existingExternalArray,
          ...nodeOnlyPackages,
          ...commonjsDependencies,
          ...nodeBuiltins,
          ...esmProblematicPackages,
        ]),
      ]

      // Detect if we're in an Electron environment
      // Electron apps typically have electron in their dependencies or use electron-specific build tools
      // For renderer processes, we need to bundle fs polyfills instead of externalizing Node.js fs
      const isElectron = 
        process.env.ELECTRON_RUN_AS_NODE === '1' ||
        process.env.ELECTRON_IS_DEV === '1' ||
        process.env.ELECTRON_BUILDER_CACHE !== undefined ||
        typeof process !== 'undefined' && process.versions?.electron ||
        (typeof window !== 'undefined' && (window as any).process?.versions?.electron) ||
        // Check if the build target suggests Electron
        userConfig.build?.target === 'electron' ||
        // Check if there are Electron-specific plugins
        (Array.isArray(userConfig.plugins) && userConfig.plugins.some((p: any) => {
          const name = p?.name || (p as Plugin)?.name
          return name?.includes('electron') || name?.includes('vite-plugin-electron')
        })) ||
        // Check package.json for electron dependency (if available in build context)
        (typeof process !== 'undefined' && process.cwd && (() => {
          try {
            const fs = require('fs')
            const path = require('path')
            const pkgPath = path.join(process.cwd(), 'package.json')
            if (fs.existsSync(pkgPath)) {
              const pkg = JSON.parse(fs.readFileSync(pkgPath, 'utf-8'))
              return !!(pkg.dependencies?.electron || pkg.devDependencies?.electron)
            }
          } catch {
            // Ignore errors - this is just a heuristic
          }
          return false
        })())

      // Create external function that checks both our list and user's function
      const externalFunction = (id: string, importer?: string, isResolved?: boolean): boolean => {
        // For Electron builds, don't externalize path, fs, and @zenfs packages - they should be bundled
        // Electron renderer processes can't use Node.js fs directly, so we need to bundle the polyfills
        if (isElectron) {
          if (id === 'path' || id === 'node:path' || 
              id === 'fs' || id === 'node:fs' || id === 'fs/promises' || id === 'node:fs/promises' ||
              id === '@zenfs/core' || id === '@zenfs/dom' || 
              id.startsWith('@zenfs/core/') || id.startsWith('@zenfs/dom/')) {
            if (debug) {
              log(`[build] Electron detected - bundling ${id} instead of externalizing`)
            }
            return false // Don't externalize - bundle it
          }
        }

        // Check if it's a node-only package (exact match or subpath)
        if (nodeOnlyPackages.some(pkg => id === pkg || id.startsWith(`${pkg}/`))) {
          if (debug) {
            log(`[build] Externalizing node-only package: ${id}`)
          }
          return true
        }

        // Check if it's a CommonJS dependency that should be externalized
        if (commonjsDependencies.some(pkg => id === pkg || id.startsWith(`${pkg}/`))) {
          if (debug) {
            log(`[build] Externalizing CommonJS dependency: ${id}`)
          }
          return true
        }

        // Check if it's an ESM package with problematic export patterns
        // These packages use `export *` re-exports that Rollup can't properly trace
        if (esmProblematicPackages.some(pkg => id === pkg || id.startsWith(`${pkg}/`))) {
          if (debug) {
            log(`[build] Externalizing ESM problematic package: ${id}`)
          }
          return true
        }

        // Check if it's a Node.js built-in
        // For Electron, we still externalize most built-ins, but not path or fs (they need polyfills)
        if (nodeBuiltins.includes(id)) {
          if (debug) {
            log(`[build] Externalizing Node.js built-in: ${id}`)
          }
          return true
        }

        // If user provided a function, call it first
        if (typeof existingExternal === 'function') {
          const userResult = existingExternal(id, importer, isResolved ?? false)
          if (userResult) return true
        }

        // Otherwise check if it's in the array
        return allExternals.includes(id)
      }

      // Configure worker format to 'es' to support code-splitting
      // This is required for packages like sqlocal that use workers with dynamic imports
      // Only set format if user hasn't explicitly configured it
      const existingWorkerConfig = userConfig.worker
      const workerConfig = existingWorkerConfig
        ? {
            ...existingWorkerConfig,
            // Only override format if not already set (default is 'iife' which causes issues)
            format: (existingWorkerConfig.format === 'es' || existingWorkerConfig.format === 'iife' 
              ? existingWorkerConfig.format 
              : 'es') as 'es' | 'iife',
          }
        : {
            format: 'es' as const,
          }

      return {
        optimizeDeps: optimizeDepsConfig,
        worker: workerConfig,
        build: {
          // Ensure CommonJS dependencies in SDK dist are transformed
          commonjsOptions: {
            include: [
              /node_modules/,
              /seed-protocol-sdk[\\/]+dist[\\/]/,
            ],
            // Transform require() calls to ESM imports
            transformMixedEsModules: true,
          },
          rollupOptions: {
            // Always use the function if we have packages to externalize
            // or if the user provided an external function
            // Otherwise, use the array if we have externals
            external:
              (nodeOnlyPackages.length > 0 || commonjsDependencies.length > 0 || typeof existingExternal === 'function')
                ? externalFunction
                : allExternals.length > 0
                ? allExternals
                : undefined,
          },
        },
      }
    },

    async resolveId(source, importer, options) {
      // Note: We don't intercept buffer here because vite-plugin-node-polyfills should handle it
      // when configured with include: ['buffer']. Intercepting here could interfere with
      // the plugin's own resolution mechanism. The transform hook will handle any require() calls.

      // Force @sinclair/typebox to use its CommonJS build during production builds
      // The ESM build uses `export * from './module.mjs'` which Rollup can't trace properly
      // The CJS build doesn't have this issue
      if (source === '@sinclair/typebox' || source === '@sinclair/typebox/value') {
        // Skip if already resolving to CJS build
        if (importer && importer.includes('@sinclair/typebox/build/cjs')) {
          return null
        }
        
        log(`Intercepting @sinclair/typebox resolution: ${source} from ${importer || 'unknown'}`)
        
        // Resolve the package first to get its location
        const resolved = await this.resolve(source, importer || PLUGIN_FILE_URL, {
          ...options,
          skipSelf: true,
        })
        
        if (resolved) {
          // Replace ESM path with CJS path
          // ESM: .../build/esm/index.mjs or .../build/esm/value/index.mjs
          // CJS: .../build/cjs/index.js or .../build/cjs/value/index.js
          const cjsPath = resolved.id
            .replace('/build/esm/', '/build/cjs/')
            .replace('.mjs', '.js')
          
          log(`Resolved @sinclair/typebox to CJS: ${cjsPath}`)
          return { id: cjsPath, moduleSideEffects: resolved.moduleSideEffects }
        }
      }

      // Intercept ALL 'path' module resolutions to ensure we use path-browserify
      // This is critical for Electron renderer processes where vite-plugin-node-polyfills
      // might create a problematic path polyfill that causes "Dynamic require" errors
      // We intercept ALL path resolutions, not just from vite optimization directories,
      // to ensure consistent behavior
      if (source === 'path' || source === 'node:path') {
        // Skip if the importer is already path-browserify (avoid circular resolution)
        if (importer && importer.includes('path-browserify')) {
          return null
        }
        
        log(`Intercepting path resolution in resolveId: ${source} from ${importer || 'unknown'}`)
        // Resolve to path-browserify instead
        const resolved = await this.resolve('path-browserify', importer || PLUGIN_FILE_URL, {
          ...options,
          skipSelf: true,
        })
        if (resolved) {
          log(`Resolved path to path-browserify: ${resolved.id}`)
          return resolved
        }
      }
      
      // Also intercept if the source is a path.mjs file from vite optimization
      if (source.includes('path.mjs') && 
          !source.includes('path-browserify') &&
          (source.includes('.vite-electron-renderer') || 
           source.includes('.vite/deps') ||
           source.includes('node_modules/.vite'))) {
        log(`Intercepting path.mjs file resolution: ${source} from ${importer}`)
        // Resolve to path-browserify instead
        const resolved = await this.resolve('path-browserify', importer || PLUGIN_FILE_URL, {
          ...options,
          skipSelf: true,
        })
        if (resolved) {
          log(`Resolved path.mjs to path-browserify: ${resolved.id}`)
          return resolved
        }
      }

      // Help resolve @zenfs/core if it's not being found
      // This can happen in browser contexts where module resolution might fail
      if (source === '@zenfs/core' || source.startsWith('@zenfs/core/')) {
        log(`Helping resolve @zenfs/core: "${source}" from ${importer}`)
        
        // Try resolving from plugin context first (SDK's node_modules)
        let resolved = await this.resolve(source, PLUGIN_FILE_URL, {
          ...options,
          skipSelf: true,
        })
        
        // If that fails and we have an importer, try resolving from the importer
        if (!resolved && importer) {
          resolved = await this.resolve(source, importer, {
            ...options,
            skipSelf: true,
          })
        }
        
        if (resolved) {
          log(`Resolved @zenfs/core to: ${resolved.id}`)
          return resolved
        }
        
        // If still not resolved, return null to let Vite handle it
        // Vite should be able to resolve from node_modules
        log(`Could not resolve @zenfs/core, letting Vite handle it`)
        return null
      }

      // Check if this is an fs-related import we should intercept
      const shouldIntercept = fsModules.includes(source) || 
        KNOWN_POLYFILL_TARGETS.some(target => source.includes(target) || source === target)

      // Also intercept node-stdlib-browser empty mock paths
      if (source.includes('node-stdlib-browser') && source.includes('mock/empty')) {
        log(`Intercepting node-stdlib-browser empty mock: "${source}"`)
        const isPromiseVariant = source.includes('promises')
        const zenfsModule = isPromiseVariant ? '@zenfs/core/promises' : '@zenfs/core'
        
        // Try resolving from plugin context first (SDK's node_modules)
        let resolved = await this.resolve(zenfsModule, PLUGIN_FILE_URL, {
          ...options,
          skipSelf: true,
        })
        
        // If that fails and we have an importer, try resolving from the importer
        if (!resolved && importer) {
          resolved = await this.resolve(zenfsModule, importer, {
            ...options,
            skipSelf: true,
          })
        }
        
        if (resolved) {
          log(`Resolved empty mock to: ${resolved.id}`)
          interceptedResolutions.set(source, resolved.id)
          return resolved
        }
        
        // If resolution fails, return null and let Vite handle it naturally
        // The alias configuration should handle the resolution
        log(`Resolution failed, letting Vite handle: ${zenfsModule}`)
        return null
      }

      if (!shouldIntercept) {
        // Also intercept if source is a Vite pre-bundled fs polyfill path or node-stdlib-browser mock
        const sourceWithoutQuery = source.split('?')[0]
        if (
          source.includes('node_fs') || 
          (source.includes('.vite/deps') && source.includes('fs') && !source.includes('@zenfs')) ||
          (source.includes('node-stdlib-browser') && (source.includes('mock/empty') || source.includes('empty.js')))
        ) {
          log(`Intercepting Vite pre-bundled fs polyfill/mock: "${source}"`)
          const isPromiseVariant = source.includes('promises')
          const zenfsModule = isPromiseVariant ? '@zenfs/core/promises' : '@zenfs/core'
          
          // For .vite/deps paths, let the load hook handle them to avoid chunk reference issues
          if (source.includes('.vite/deps')) {
            // Return null to let Vite continue, then the load hook will intercept
            return null
          }
          
          // For other cases, resolve the module
          let resolved = await this.resolve(zenfsModule, importer || PLUGIN_FILE_URL, {
            ...options,
            skipSelf: true,
          })
          
          if (resolved) {
            log(`Resolved pre-bundled fs to: ${resolved.id}`)
            interceptedResolutions.set(source, resolved.id)
            return resolved
          }
          
          // Fallback: return the module specifier
          log(`Fallback: returning module specifier: ${zenfsModule}`)
          interceptedResolutions.set(source, zenfsModule)
          return { id: zenfsModule, external: false }
        }
        return null
      }

      log(`Intercepting resolution: "${source}" from ${importer}`)

      // Determine the correct ZenFS module
      const isPromiseVariant = source.includes('promises')
      const zenfsModule = isPromiseVariant ? '@zenfs/core/promises' : '@zenfs/core'

      // First, try resolving from the plugin's context (SDK's node_modules)
      // This ensures we use the SDK's dependencies even if the consuming project doesn't have them
      let resolved = await this.resolve(zenfsModule, PLUGIN_FILE_URL, {
        ...options,
        skipSelf: true,
      })

      // If that fails, try resolving from the original importer (project's node_modules)
      if (!resolved && importer) {
        resolved = await this.resolve(zenfsModule, importer, {
          ...options,
          skipSelf: true,
        })
      }

      if (resolved) {
        log(`Resolved to: ${resolved.id}`)
        interceptedResolutions.set(source, resolved.id)
        return resolved
      }

      // Fallback: return the module specifier and let Vite handle it
      // Vite should be able to resolve from parent node_modules automatically
      log(`Fallback resolution for: ${zenfsModule}`)
      return { id: zenfsModule, external: false }
    },

    shouldTransformCachedModule({ id, code }) {
      // Force transformation of cached fs polyfill modules
      const idWithoutQuery = id.split('?')[0]
      const isFsPolyfill = 
        idWithoutQuery.includes('node_fs') || 
        (idWithoutQuery.includes('.vite/deps') && idWithoutQuery.includes('fs') && !idWithoutQuery.includes('@zenfs')) ||
        (idWithoutQuery.includes('node-stdlib-browser') && (idWithoutQuery.includes('mock/empty') || idWithoutQuery.includes('empty.js')))
      
      if (isFsPolyfill) {
        log(`Forcing transformation of cached fs polyfill: ${id}`)
        return true
      }
      return false
    },

    load(id) {
      // Remove query parameters for matching (e.g., ?v=392cb483)
      const idWithoutQuery = id.split('?')[0]
      
      // Early check for path polyfill files - check this first before other logic
      // This catches vite-plugin-node-polyfills path polyfills that may use require() or have other issues
      // We intercept ALL path polyfills from Vite's optimization directories to ensure compatibility
      if (idWithoutQuery.includes('path') && 
          !idWithoutQuery.includes('path-browserify') && 
          (idWithoutQuery.includes('.vite-electron-renderer') || 
           idWithoutQuery.includes('.vite/deps') ||
           idWithoutQuery.includes('node_modules/.vite'))) {
        // Always intercept path polyfills from vite-plugin-node-polyfills
        // The polyfill may have issues even if it doesn't contain require('path')
        log(`Intercepting load of path polyfill from vite-plugin-node-polyfills: ${id} - using path-browserify`)
        return `
// Intercepted by seed-vite-plugin to prevent "Dynamic require of path is not supported" errors
// Re-export from path-browserify which is ESM-compatible
// Note: path-browserify is CommonJS, so we use namespace import
import * as pathBrowserify from 'path-browserify';
export default pathBrowserify;
export const { basename, dirname, extname, format, isAbsolute, join, normalize, parse, relative, resolve, sep, delimiter, posix, win32 } = pathBrowserify;
`
      }
      
      // Fix SDK export patterns in load hook as fallback (for cases where transform doesn't run)
      // This handles the case where Vite loads the file directly via /@fs/
      if (id.includes('seed-protocol-sdk') && id.includes('events/index.js')) {
        try {
          // Use Node.js fs module with ESM import (already imported at top)
          let code = readFileSync(idWithoutQuery, 'utf-8')
          // Check if the file uses the const + separate export pattern
          if (code.includes('const waitForEvent =') && code.includes('export { waitForEvent }')) {
            if (debug) {
              log(`[load] Fixing export pattern in SDK events module: ${id}`)
            }
            // Transform: const waitForEvent = ...; export { waitForEvent };
            // To: export const waitForEvent = ...;
            code = code
              .replace(/const waitForEvent =/g, 'export const waitForEvent =')
              .replace(/export \{ waitForEvent \};?\s*/g, '')
            return code
          }
        } catch (e) {
          // If we can't read it, let Vite handle it normally
          if (debug) {
            log(`[load] Could not read file to fix export pattern: ${id}`, e)
          }
        }
      }
      
      // NOTE: Virtual process polyfill has been removed because virtual modules (\0-prefixed)
      // don't work with esbuild during Vite's dependency optimization phase.
      // Process polyfilling is now handled by vite-plugin-node-polyfills when configured,
      // or by the npm 'process' package being bundled normally.

      // Intercept Vite's pre-bundled fs polyfill and replace it with ZenFS
      // Also intercept node-stdlib-browser's empty mock
      // Handle both regular paths and /@fs/ prefixed paths
      const isFsPolyfill = 
        idWithoutQuery.includes('node_fs') || 
        (idWithoutQuery.includes('.vite/deps') && idWithoutQuery.includes('fs') && !idWithoutQuery.includes('@zenfs')) ||
        (idWithoutQuery.includes('node-stdlib-browser') && (idWithoutQuery.includes('mock/empty') || idWithoutQuery.includes('empty.js')))
      
      if (isFsPolyfill) {
        log(`Intercepting load of fs polyfill/mock file: ${id}`)
        const isPromiseVariant = idWithoutQuery.includes('promises')
        const zenfsModule = isPromiseVariant ? '@zenfs/core/promises' : '@zenfs/core'
        
        // Return a re-export from ZenFS
        return `export * from '${zenfsModule}'; export { default } from '${zenfsModule}';`
      }

      // Intercept the actual npm buffer and events packages which use require()
      // This prevents "require is not defined" errors in ESM contexts
      // These packages from npm are CommonJS and don't work in ESM
      // When vite-plugin-node-polyfills is configured, it provides polyfills
      // Match any buffer.mjs, events.mjs, util.mjs, or process.mjs files
      // 
      // NOTE: We DO intercept Vite-optimized files in .vite-electron-renderer/, .vite/deps/, etc.
      // because Vite's esbuild may not fully convert all require() calls to ESM, especially
      // for packages like 'buffer' that have complex CommonJS patterns. We provide a self-contained
      // Buffer polyfill that works in browser/Electron renderer without requiring globals.
      const isViteOptimized = 
        idWithoutQuery.includes('.vite-electron-renderer/') ||
        idWithoutQuery.includes('.vite/deps/') ||
        idWithoutQuery.includes('node_modules/.vite/')
      
      // Match buffer files - including Vite-optimized ones since they may still have require()
      const isNpmBufferPackage = 
        idWithoutQuery.includes('/buffer') && 
        (idWithoutQuery.endsWith('buffer.mjs') || 
         idWithoutQuery.endsWith('/buffer/index.js') ||
         idWithoutQuery.endsWith('/buffer/index.mjs') ||
         (idWithoutQuery.includes('node_modules/buffer') && idWithoutQuery.endsWith('.mjs')) ||
         (idWithoutQuery.includes('node_modules/buffer') && idWithoutQuery.endsWith('/index.js')) ||
         // Also match Vite-optimized buffer files
         (isViteOptimized && idWithoutQuery.endsWith('buffer.mjs')))
      
      const isNpmEventsPackage = 
        idWithoutQuery.includes('/events') && 
        (idWithoutQuery.endsWith('events.mjs') || 
         idWithoutQuery.endsWith('/events/index.js') ||
         idWithoutQuery.endsWith('/events/index.mjs') ||
         (idWithoutQuery.includes('node_modules/events') && idWithoutQuery.endsWith('.mjs')) ||
         (idWithoutQuery.includes('node_modules/events') && idWithoutQuery.endsWith('/index.js')) ||
         // Also match Vite-optimized events files
         (isViteOptimized && idWithoutQuery.endsWith('events.mjs')))
      
      // Only intercept Node.js "path" module polyfills, not path-browserify
      // The pattern should match files that are clearly the Node.js path polyfill
      // but not path-browserify itself (which would cause circular references)
      // Note: We don't intercept path polyfills here because:
      // 1. vite-plugin-node-polyfills should handle path when configured with include: ['path']
      // 2. The alias configuration already redirects 'path' to 'path-browserify'
      // 3. Intercepting here can cause circular reference issues
      // If you see "Dynamic require of path" errors, ensure vite-plugin-node-polyfills
      // is configured with include: ['path'] and the alias is set up correctly
      
      if (isNpmBufferPackage) {
        log(`Intercepting npm buffer package load: ${id} - providing self-contained Buffer polyfill`)
        // Provide a self-contained Buffer polyfill that works without globals or require()
        // This is based on the feross/buffer implementation but simplified for browser use
        return `
// Intercepted by seed-vite-plugin - Self-contained Buffer polyfill for browser/Electron renderer
// First check if a global Buffer already exists (e.g., from vite-plugin-node-polyfills)
const existingBuffer = typeof globalThis !== 'undefined' && globalThis.Buffer 
  ? globalThis.Buffer 
  : typeof global !== 'undefined' && global.Buffer 
    ? global.Buffer 
    : typeof window !== 'undefined' && window.Buffer 
      ? window.Buffer 
      : null;

// If no global Buffer, create a minimal polyfill
const Buffer = existingBuffer || (function() {
  // Minimal Buffer implementation for browser environments
  // Based on feross/buffer but simplified
  
  const K_MAX_LENGTH = 0x7fffffff;
  
  function Buffer(arg, encodingOrOffset, length) {
    if (typeof arg === 'number') {
      return allocUnsafe(arg);
    }
    return from(arg, encodingOrOffset, length);
  }
  
  Buffer.TYPED_ARRAY_SUPPORT = true;
  Buffer.poolSize = 8192;
  
  function from(value, encodingOrOffset, length) {
    if (typeof value === 'string') {
      return fromString(value, encodingOrOffset);
    }
    if (ArrayBuffer.isView(value)) {
      return fromArrayView(value);
    }
    if (value == null) {
      throw new TypeError('The first argument must be one of type string, Buffer, ArrayBuffer, Array, or Array-like Object.');
    }
    if (Array.isArray(value) || (typeof value === 'object' && value.length !== undefined)) {
      return fromArrayLike(value);
    }
    if (value instanceof ArrayBuffer) {
      return fromArrayBuffer(value, encodingOrOffset, length);
    }
    throw new TypeError('The first argument must be one of type string, Buffer, ArrayBuffer, Array, or Array-like Object.');
  }
  
  Buffer.from = from;
  
  function allocUnsafe(size) {
    if (size < 0 || size > K_MAX_LENGTH) {
      throw new RangeError('Invalid typed array length');
    }
    const buf = new Uint8Array(size);
    Object.setPrototypeOf(buf, Buffer.prototype);
    return buf;
  }
  
  Buffer.alloc = function(size, fill, encoding) {
    const buf = allocUnsafe(size);
    if (fill !== undefined) {
      if (typeof fill === 'number') {
        buf.fill(fill);
      } else {
        buf.fill(0);
      }
    } else {
      buf.fill(0);
    }
    return buf;
  };
  
  Buffer.allocUnsafe = allocUnsafe;
  Buffer.allocUnsafeSlow = allocUnsafe;
  
  function fromString(string, encoding) {
    encoding = encoding || 'utf8';
    const encoder = new TextEncoder();
    const bytes = encoder.encode(string);
    const buf = allocUnsafe(bytes.length);
    buf.set(bytes);
    return buf;
  }
  
  function fromArrayLike(array) {
    const buf = allocUnsafe(array.length);
    for (let i = 0; i < array.length; i++) {
      buf[i] = array[i] & 255;
    }
    return buf;
  }
  
  function fromArrayView(view) {
    const buf = allocUnsafe(view.byteLength);
    buf.set(new Uint8Array(view.buffer, view.byteOffset, view.byteLength));
    return buf;
  }
  
  function fromArrayBuffer(arrayBuffer, byteOffset, length) {
    byteOffset = byteOffset || 0;
    length = length === undefined ? arrayBuffer.byteLength - byteOffset : length;
    const buf = allocUnsafe(length);
    buf.set(new Uint8Array(arrayBuffer, byteOffset, length));
    return buf;
  }
  
  Buffer.isBuffer = function(obj) {
    return obj != null && obj._isBuffer === true;
