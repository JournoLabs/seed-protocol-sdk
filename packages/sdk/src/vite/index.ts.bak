        if (allEsmSafeModules.some(mod => id.includes(mod))) {
          // Still apply existing transformations for these files if they have path/fs imports
          return handleExistingTransformations(code, id)
        }
        
        // Process Vite-optimized files and typebox CJS files
        // Vite-optimized files are pre-bundled and may contain unconverted require() calls
        // Typebox CJS files need require() transformation when bundled into production output
        const isViteOptimized = 
          id.includes('.vite/deps') || 
          id.includes('.vite-electron-renderer') ||
          id.includes('node_modules/.vite')
        
        // Also process typebox CJS files (they use require() internally)
        const isTypeboxCjs = id.includes('@sinclair/typebox/build/cjs')
        
        // In production builds, also process bundled files that contain require() calls
        // This handles cases where CJS code (like typebox) is bundled into the final output
        // A bundled file is any file that's not in node_modules or .vite directories
        const isProduction = config?.mode === 'production'
        const isBundledOutput = isProduction && 
          !id.includes('node_modules') && 
          !id.includes('.vite')
        
        if (isViteOptimized || isTypeboxCjs || isBundledOutput) {
          // Pattern matches: require('module'), require("module"), require(`module`)
          // Also matches minified versions: require('module'), require("module")
          // Captures the module name in group 2
          // Does NOT match: require(variable), require('./relative') [relative is skipped later]
          // More flexible pattern to catch minified code: require('x'),require("x"),require(`x`)
          const requirePattern = /\brequire\s*\(\s*(['"`])([^'"`]+)\1\s*\)/g
          
          // Test if there are any require() calls
          const hasRequireCalls = requirePattern.test(code)
          
          if (hasRequireCalls) {
            // Reset regex for collection pass
            requirePattern.lastIndex = 0
            
            // Merge user-provided module replacements with defaults
            const allModuleReplacements = { ...DEFAULT_MODULE_REPLACEMENTS, ...moduleReplacements }
            
            // Collect all require() calls
            const requires = new Map<string, { varName: string; replacement: string }>()
            let match
            
            while ((match = requirePattern.exec(code)) !== null) {
              const moduleName = match[2]
              
              // Skip relative requires (these are handled by Vite's module resolution)
              if (moduleName.startsWith('.') || moduleName.startsWith('/')) {
                continue
              }
              
              // Skip if we've already seen this module
              if (requires.has(moduleName)) {
                continue
              }
              
              // Get replacement module name (use mapping if available, otherwise use original)
              const replacement = allModuleReplacements[moduleName] || moduleName
              
              // Generate safe variable name (replace non-alphanumeric chars with underscore)
              const varName = `__require_${moduleName.replace(/[^a-zA-Z0-9]/g, '_')}`
              
              requires.set(moduleName, { varName, replacement })
            }
            
            // Only transform if we found non-relative requires
            if (requires.size > 0) {
              const context = isBundledOutput ? 'bundled output' : (isTypeboxCjs ? 'typebox CJS' : 'Vite-optimized')
              log(`[require-transformer] Transforming ${requires.size} require() calls in ${context} file: ${id}`)
              
              // Build import statements to prepend
              const imports = Array.from(requires.entries())
                .map(([originalMod, { varName, replacement }]) => {
                  log(`  - require('${originalMod}') -> import * as ${varName} from '${replacement}'`)
                  return `import * as ${varName} from '${replacement}';`
                })
                .join('\n')
              
              // Replace require() calls with the imported variable names
              let transformed = code
              for (const [mod, { varName }] of requires) {
                // Escape special regex characters in module name
                const escapedMod = mod.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
                const pattern = new RegExp(
                  `\\brequire\\s*\\(\\s*['"\`]${escapedMod}['"\`]\\s*\\)`,
                  'g'
                )
                transformed = transformed.replace(pattern, varName)
              }
              
              // Prepend imports to the transformed code
              const finalCode = imports + '\n' + transformed
              
              // Also apply existing transformations to handle any static imports
              const existingResult = handleExistingTransformations(finalCode, id)
              if (existingResult) {
                return existingResult
              }
              
              return {
                code: finalCode,
                map: null,
              }
            }
          }
        }
      }

      // === FALLBACK: EXISTING TRANSFORMATIONS ===
      // For non-Vite-optimized files or when require() transformer is disabled
      
      // Skip node_modules except for specific problematic packages
      if (id.includes('node_modules') && !id.includes('@seedprotocol')) {
        return null
      }

      // Apply existing path/fs import transformations
      return handleExistingTransformations(code, id)
    },

    transformIndexHtml(html) {
      if (!autoInit) return html

      // Inject ZenFS initialization script before other scripts
      // Use a data URL approach or let the consuming app handle initialization
      // The issue is that bare module specifiers in HTML scripts need to be resolved by Vite
      // We'll use a script that Vite can process, but we need to ensure @zenfs/core is available
      const debugFlag = debug ? 'true' : 'false'
      // Check if we're in Electron (where fs might be available natively)
      // Check multiple ways since nodeIntegration might be disabled
      const isElectronCheck = `
  // Check if we're in Electron (renderer or main process)
  // Try multiple detection methods since nodeIntegration might be disabled
  const isElectron = 
    (typeof process !== 'undefined' && process.versions && process.versions.electron) ||
    (typeof window !== 'undefined' && window.process && window.process.versions && window.process.versions.electron) ||
    (typeof navigator !== 'undefined' && navigator.userAgent && navigator.userAgent.includes('Electron'));
  const isElectronRenderer = typeof window !== 'undefined' && isElectron;
`
      const initScript = `
<script type="module">
  ${isElectronCheck}
  // Try to import @zenfs/core - if it fails, the consuming app needs to install it
  // or handle initialization themselves
  // In Electron, fs might be available natively, so ZenFS might not be needed
  (async () => {
    // Skip auto-init in Electron main process (where Node.js fs is available)
    if (typeof window === 'undefined') {
      if (${debugFlag}) {
        console.log('[seed-protocol] Skipping ZenFS auto-init in non-browser environment');
      }
      return;
    }
    
    // In Electron renderer, try to initialize ZenFS, but don't error if it fails
    // (native fs might be available via nodeIntegration)
    try {
      const { configure } = await import('@zenfs/core');
      const { IndexedDB } = await import('@zenfs/dom');
      
      window.__seedFsReady = configure({
        mounts: {
          '/': IndexedDB,
        },
      }).then(() => {
        if (${debugFlag}) {
          console.log('[seed-protocol] ZenFS initialized');
        }
      }).catch(err => {
        console.error('[seed-protocol] ZenFS initialization failed:', err);
      });
    } catch (err) {
      // In Electron renderer, fs might be available natively, so this is not necessarily an error
      // Never show warnings in Electron - silently fail since native fs might be available
      // Only show warnings in non-Electron environments when debug is enabled
      if (!isElectronRenderer) {
        if (${debugFlag}) {
          console.warn('[seed-protocol] Could not auto-initialize ZenFS:', err);
          console.warn('[seed-protocol] Make sure @zenfs/core and @zenfs/dom are installed');
        }
      }
      // In Electron renderer, don't log anything - native fs is likely available
    }
  })();
</script>`

      // Insert before closing head tag or at the start of body
      if (html.includes('</head>')) {
        return html.replace('</head>', `${initScript}\n</head>`)
      }
      
      return html.replace('<body>', `<body>\n${initScript}`)
    },

    buildEnd() {
      if (debug && interceptedResolutions.size > 0) {
        log('Summary of intercepted resolutions:')
        for (const [source, target] of interceptedResolutions) {
          log(`  ${source} -> ${target}`)
        }
      }
    },
  }

  /**
   * Cleanup plugin: catches any remaining fs references in the final bundle
   */
  const cleanupPlugin: Plugin = {
    name: 'seed-protocol:cleanup',
    enforce: 'post',
    apply: 'build',

    // Transform hook to catch node:fs and node:crypto imports that weren't caught earlier
    // This is especially important for packages like drizzle-orm/migrator that import these
    renderChunk(code, chunk, options) {
      // Check if this chunk contains require() calls (which will fail in browser/Electron renderer)
      const requireMatches = code.match(/\brequire\s*\(\s*['"`]([^'"`]+)['"`]\s*\)/g) || []
      const hasRequire = requireMatches.length > 0
      
      // Check if this chunk contains node:fs or node:crypto imports that need transformation
      const hasNodeFs = /from\s*['"`]node:fs['"`]/.test(code) || /import\s+.*\s+from\s*['"`]node:fs['"`]/.test(code)
      const hasNodeCrypto = /from\s*['"`]node:crypto['"`]/.test(code)
      
      if (hasRequire) {
        const requireModules = requireMatches.map(m => {
          const match = m.match(/['"`]([^'"`]+)['"`]/)
          return match ? match[1] : 'unknown'
        })
        log(`[cleanup] WARNING: Found ${requireMatches.length} require() call(s) in chunk ${chunk.name}: ${requireModules.join(', ')}`)
      }
      
      if (hasNodeFs || hasNodeCrypto) {
        
        let transformedCode = code
        
        // Replace node:fs imports with @zenfs/core
        if (hasNodeFs) {
          // Match: import xxx from "node:fs" or import xxx from 'node:fs'
          transformedCode = transformedCode.replace(
            /import\s+(\w+|\*\s+as\s+\w+|\{[^}]+\})\s+from\s*['"`]node:fs['"`]/g,
            (match, importPart) => {
              log(`[cleanup] Transforming node:fs import in chunk ${chunk.name}: ${match}`)
              return `import ${importPart} from '@zenfs/core'`
            }
          )
        }
        
        // Replace node:crypto imports with a polyfill (crypto-browserify or webcrypto)
        // For now, we'll replace with a dynamic import that can be polyfilled
        if (hasNodeCrypto) {
          // For crypto, we can't easily polyfill, so just log a warning
          // The user should configure vite-plugin-node-polyfills with include: ['crypto']
          log(`[cleanup] Warning: node:crypto import found in chunk ${chunk.name}. Configure vite-plugin-node-polyfills with include: ['crypto'] for browser support.`)
        }
        
        if (transformedCode !== code) {
          return {
            code: transformedCode,
            map: null, // Ideally we'd generate a source map, but for simplicity we return null
          }
        }
      }
      
      return null // No transformation needed
    },

    generateBundle(options, bundle) {
      for (const [fileName, chunk] of Object.entries(bundle)) {
        if (chunk.type !== 'chunk') continue

        // Check for any remaining problematic fs and buffer references
        // We need to check line by line to avoid false positives from transformed imports
        const lines = chunk.code.split('\n')
        let hasIssue = false
        const problematicLines: Array<{ line: number; content: string }> = []

        for (let i = 0; i < lines.length; i++) {
          const line = lines[i]
          
          // Skip if this line contains transformed polyfill imports
          if (line.includes('@zenfs') || line.includes('memfs') || line.includes('browserfs')) {
            continue
          }

          // Check for problematic patterns
          const patterns = [
            /require\s*\(\s*['"`]fs['"`]\s*\)/,
            /from\s*['"`]fs['"`]/,
            /from\s*['"`]fs\/promises['"`]/,
            /from\s*['"`]node:fs['"`]/,
            /from\s*['"`]node:fs\/promises['"`]/,
            /__vite-browser-external.*fs/,
            /require\s*\(\s*['"`]buffer['"`]\s*\)/,
            /__vite-browser-external.*buffer/,
          ]

          for (const pattern of patterns) {
            if (pattern.test(line)) {
              hasIssue = true
              problematicLines.push({ line: i + 1, content: line.substring(0, 150) })
              break // Only log each line once
            }
          }
        }

        if (hasIssue) {
          // Only warn if debug is enabled, or if it's a clear error (require() or __vite-browser-external)
          // For Electron builds, static imports might resolve at runtime even if they look problematic
          const hasClearError = problematicLines.some(p => 
            p.content.includes('require(') || p.content.includes('__vite-browser-external')
          )
          
          // Check if this might be an Electron build where fs could be available
          // In that case, these might be acceptable (though not recommended)
          const mightBeElectron = fileName.includes('electron') || 
            process.env.ELECTRON_RUN_AS_NODE === '1' ||
            process.env.ELECTRON_IS_DEV === '1'
          
          // Warn if:
          // 1. Debug is enabled (user wants to see all warnings)
          // 2. It's a clear error (require() or __vite-browser-external) - these will definitely fail
          // 3. It's not an Electron build (browser builds should never have fs)
          if (debug || (hasClearError && !mightBeElectron) || (!mightBeElectron && !hasClearError)) {
            const severity = hasClearError ? 'Error' : 'Warning'
            log(`${severity}: Potential unresolved fs reference in ${fileName}`)
            if (debug && problematicLines.length > 0) {
              problematicLines.forEach(({ line, content }) => {
                log(`  Line ${line}: ${content}...`)
              })
            } else if (hasClearError) {
              // Always show context for clear errors
              problematicLines.slice(0, 3).forEach(({ line, content }) => {
                log(`  Line ${line}: ${content}...`)
              })
            }
          }
        }
      }
    },
  }

  // Plugin to check for user-provided polyfills configuration
  // This is primarily useful when includeNodePolyfills: false is set
  const polyfillsAutoConfigPlugin: Plugin = {
    name: 'seed-protocol:auto-polyfills',
    enforce: 'pre',
    configResolved(resolvedConfig) {
      // Only log warnings/info in debug mode when user has disabled auto-polyfills
      if (!includeNodePolyfills && debug) {
        // Check if user has provided their own vite-plugin-node-polyfills
        const plugins = resolvedConfig.plugins || []
        const hasUserPolyfills = plugins.some((p: any) => {
          const name = p?.name || ''
          return name === 'vite-plugin-node-polyfills' || name.includes('node-polyfills')
        })
        
        if (!hasUserPolyfills) {
          log('[seed-vite-plugin] includeNodePolyfills is false and no user-provided polyfills detected')
          log('[seed-vite-plugin] Make sure to add vite-plugin-node-polyfills manually if you need polyfills')
        } else {
          log('[seed-vite-plugin] User-provided vite-plugin-node-polyfills detected')
        }
      }
    },
  }

  // Build the plugins array
  const plugins: Plugin[] = [polyfillsAutoConfigPlugin, observerPlugin, mainPlugin, cleanupPlugin]
  
  // Conditionally include vite-plugin-node-polyfills
  if (includeNodePolyfills) {
    plugins.push(nodePolyfills({
      // Exclude fs-related modules since we use @zenfs/core for those
      // Also exclude readline and module which can't be properly polyfilled in browsers
      // Note: Type assertion needed as the type definitions don't include all valid module variants
      exclude: ['readline', 'readline/promises', 'fs', 'fs/promises', 'node:fs', 'node:fs/promises', 'module'] as any,
      // Include all common Node.js polyfills needed by crypto-browserify chain
      // string_decoder is needed by cipher-base -> create-hash -> crypto-browserify
      include: ['crypto', 'stream', 'util', 'path', 'buffer', 'events', 'process', 'string_decoder'],
      globals: { Buffer: true, global: true, process: true },
      protocolImports: true,
    }))
  }
  
  return plugins
}

/**
 * Helper to ensure ZenFS is ready before using fs operations
 */
export async function waitForFs(): Promise<void> {
  if (typeof window !== 'undefined' && window.__seedFsReady) {
    await window.__seedFsReady
  }
}

// Type augmentation for the window object
declare global {
  interface Window {
    __seedFsReady?: Promise<void>
  }
}

// Note: seedVitePlugin is exported as a named export above (line 246)
// Use: import { seedVitePlugin } from '@seedprotocol/sdk/vite'