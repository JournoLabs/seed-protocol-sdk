        // Also handle: import path from 'node:path' -> import * as path from 'path-browserify'
        const defaultPathImportPattern = /import\s+(\w+)\s+from\s+['"`](path|node:path)['"`]/g
        if (defaultPathImportPattern.test(codeToTransform)) {
          hasPathImports = true
